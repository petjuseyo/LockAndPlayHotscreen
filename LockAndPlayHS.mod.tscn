################################################################################
## LOCKED SESSION & CYCLE
################################################################################


##
## Cycles have a duration and an action \"id\" is called by Session at the end of
## the duration before starting a whole new cycle.
##
class CycleRunner extends RefCounted:

	## id should be the same as a game id
	var id: String
	## how long this cycle last until it repeats
	var duration: float
	## timestamp of the start of this cycle (default to now)
	var start_time: float

	func _init(_id: String, _duration: float, _start_time: float = 0.0):
		duration = _duration
		id = _id
		
		if _start_time > 0:
			start_time = _start_time
		else:
			start_time = Time.get_unix_time_from_system()

	## Update cycle and call callback if cycle ended before starting new cycle.
	func update(callback: Callable):
		var now = Time.get_unix_time_from_system()
		
		# Catch up in case app was closed for long time
		while now >= start_time + duration:
			if callback.is_valid():
				callback.call(self)
			
			start_time += duration

	func get_time_left() -> float:
		var now = Time.get_unix_time_from_system()
		return maxf(0.0, (start_time + duration) - now)

	func to_dict() -> Dictionary:
		return {
			\"duration\": duration,
			\"start_time\": start_time,
			\"id\": id
		}

	static func from_dict(data: Dictionary) -> CycleRunner:
		return CycleRunner.new(
			data.get(\"id\", \"\"),
			data.get(\"duration\", 0.0),
			data.get(\"start_time\", 0.0)
		)


##
## Locked session. Manages cycles and lock time.
##
class LockedSession extends RefCounted:
	
	const _mod_src_path := \"lock_and_play_src/\"
	var Utils = preload(_mod_src_path + \"Utils.gd\")
	var Data = preload(_mod_src_path + \"Data.gd\")
	
	# HS.profile_id
	var profile_id: int = -1
	
	const DEFAULT_SAVE_PATH := \"./lockandplay_session_{0}.json\"
	var save_path: String:
		get:
			if profile_id != -1:
				return DEFAULT_SAVE_PATH.format([profile_id])
			return DEFAULT_SAVE_PATH.format([\"main\"])
	
	const SAVE_INTERVAL := 30.0
	var _save_timer: float = 0.0
	var _prev_tick: float = 0.0

	enum Behavior {
		NO_LOCK, # no lock when HS restarts
		RESUME_TIMER, # resumes exactly where it left off
		SUBTRACT_OFF_TIME, # account for the time HS wasn't running (computer shutdown)
	}
	
	var behavior: Behavior = Behavior.RESUME_TIMER
	var duration: float = 0.0
	var start_time: float = 0.0 
	var save_time: float = 0.0
	var accumulated_time: float = 0.0
	var origin_start_time: float = 0.0 # never changes
	var origin_duration: float = 0.0
	
	var is_running: bool = false
	var is_finished: bool = false
	
	var cycles: Array[CycleRunner] = []
	# Global callback
	var cycle_callback: Callable
	
	func _init(_profile_id: int) -> void:
		profile_id = _profile_id
	
	func start(_duration: int = 0, _behavior: Behavior = Behavior.RESUME_TIMER):
		Utils.loginfo(\"LockedSession: started - duration=%s, behavior=%s\" % [str(_duration), str(_behavior)])
		is_running = true
		is_finished = false
		behavior = _behavior
		duration = _duration
		origin_start_time = Time.get_unix_time_from_system()
		start_time = origin_start_time
		origin_duration = duration
		save()
		# signal that we just entered locked mode
		Data.lock_started.emit()
		
	func pause():
		Utils.loginfo(\"LockedSession: paused\")
		save()
		Data.lock_paused.emit()
		
	func resume():
		Utils.loginfo(\"LockedSession: resumed\")
		
		if is_finished:
			return false
		
		var now := Time.get_unix_time_from_system()
		# If this resume follows a crash, computer shutdown etc
		var offline_time := maxf(0.0, now - save_time)
		
		match behavior:
			Behavior.NO_LOCK:
				stop()
				return false
			
			Behavior.RESUME_TIMER:
				# Timer continues normally
				for cycle in cycles:
					cycle.start_time += offline_time
			
			Behavior.SUBTRACT_OFF_TIME:
				# Extend session by offline time
				accumulated_time += offline_time
		
		start_time = now
		save_time = start_time
		is_running = true
		is_finished = false
		save()
		Data.lock_resumed.emit()
		return true
	
	func stop():
		Utils.loginfo(\"LockedSession: stopped\")
		is_running = false
		is_finished = true
		save()
		Data.lock_ended.emit()
	
	func add_cycle(cycle: CycleRunner):
		cycles.append(cycle)
		save()
	
	func get_cycle(id: String):
		return cycles.filter(func(cycle):
			return cycle.id == id
		).front()
	
	func update():
		if not is_running:
			return
		
		var now = Time.get_unix_time_from_system()
		
		for cycle in cycles:
			cycle.update(cycle_callback)
		
		if duration > 0.0 and get_elapsed() >= duration:
			print(duration)
			stop()
			return
		
		#print(to_dict())
		
		_save_timer += now - _prev_tick
		if _save_timer >= SAVE_INTERVAL:
			_save_timer = 0.0
			save()
		_prev_tick = now
		
	func get_time_left() -> float:
		return maxf(0.0, duration - get_elapsed())
		
	func get_elapsed() -> float:
		if is_running:
			var now := Time.get_unix_time_from_system()
			if save_time > 0:
				return accumulated_time + (Time.get_unix_time_from_system() - save_time)
			else:
				return accumulated_time + (Time.get_unix_time_from_system() - start_time)
		return accumulated_time
	
	# ##########################################################################
	# Persistence
	# ##########################################################################

	func save():
		var data = to_dict()
		var file = FileAccess.open(save_path, FileAccess.WRITE)
		if file:
			file.store_string(JSON.stringify(data))
			file.close()


	func restore() -> bool:
		if not FileAccess.file_exists(save_path):
			return false
		
		var file := FileAccess.open(save_path, FileAccess.READ)
		if file == null:
			Utils.logerror(\"LockedSession: could not open save file\")
			return false
		
		var content = file.get_as_text()
		file.close()
		
		var data = JSON.parse_string(content)
		if data == null:
			Utils.logerror(\"LockedSession: corrupt save file - discarding\")
			return false
		
		from_dict(data)
		
		if is_finished and is_running:
			Utils.logdebug(\"LockedSession: session.is_finished and session.is_finished both 'true' on restore()\")
		
		# If session was active before shutdown,
		# we resume automatically
		if is_running:
			return resume()
		else:
			return false
		
		
	func to_dict() -> Dictionary:
		var now := Time.get_unix_time_from_system()
		if save_time > 0:
			accumulated_time += now - save_time
		else:
			accumulated_time += now - start_time
		save_time = now
		var data := {
			\"behavior\": behavior,
			\"duration\": duration,
			\"start_time\": start_time,
			\"save_time\": save_time,
			\"accumulated_time\": accumulated_time,
			\"origin_start_time\": origin_start_time,
			\"origin_duration\": origin_duration,
			\"is_running\": is_running,
			\"is_finished\": is_finished,
			\"cycles\": []
		}
		for c in cycles:
			data[\"cycles\"].append(c.to_dict())
		return data

	func from_dict(d: Dictionary) -> void:
		behavior = d.get(\"behavior\", Behavior.RESUME_TIMER)
		duration = d.get(\"duration\", 0.0)
		start_time = d.get(\"start_time\", 0.0)
		save_time = d.get(\"save_time\", 0.0)
		accumulated_time = d.get(\"accumulated_time\", 0.0)
		origin_start_time =  d.get(\"origin_start_time\", 0.0)
		origin_duration =  d.get(\"origin_duration\", 0.0)
		is_running = d.get(\"is_running\", false)
		is_finished = d.get(\"is_finished\", false)
		
		cycles.clear()
		for c_data in d.get(\"cycles\", []):
			cycles.append(CycleRunner.from_dict(c_data))
		

	func delete_save():
		if FileAccess.file_exists(save_path):
			DirAccess.remove_absolute(save_path)
"

