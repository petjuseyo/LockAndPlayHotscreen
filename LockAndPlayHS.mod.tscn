script/source = "class_name LockAndPlayHS
extends Node

const _mod_src_path := \"lock_and_play_src/\"
var Utils = preload(_mod_src_path + \"Utils.gd\")
var Data = preload(_mod_src_path + \"Data.gd\")


var session: LockedSession = LockedSession.new(HS.profile_id)

var _modified_locked_menu = null

# hboxcontainer containing the game button launcher and game infos displayed on
# the locked screen
# can be accessed by game name, ie {\"dice\": hboxref,}
# useful nodes inside are TooltipAnchorRich and GameLauncherButton
var _game_launcher_containers = {}

#var is_locked: bool:
	#get:
		##return HS.menu.has_node(\"LockedMenu\")
		#return HS.config_reader.phs_lock_data.is_locked == \"true\"
#var is_resumed_session: bool:
	#get:
		#if HS.menu.has_node(\"LockedMenu\"):
			#return HS.menu.get_node(\"LockedMenu\").is_hotscreen_restarting
		#return false


func _notification(what):
	if what == NOTIFICATION_WM_CLOSE_REQUEST:
		Utils.logdebug(\"NOTIFICATION_WM_CLOSE_REQUEST received\")
		if session and session.is_running and not session.is_finished:
			session.pause()
			write_hotscreen_save()
	if what == NOTIFICATION_APPLICATION_FOCUS_OUT:
		#Utils.logdebug(\"NOTIFICATION_APPLICATION_FOCUS_OUT received\")
		if session and session.is_running and not session.is_finished:
			session.save()
			write_hotscreen_save()

# this function is called before adding the mod to the tree to set the last saved parameters
func load_save_dict(parameters: Dictionary):
	Utils.logdebug(\"LOAD_SAVE_DICT profile=%s\" % [HS.profile_id])
	
	# dice
	Data.games.dice.enabled = parameters.get(\"dice.enabled\", Data.games.dice.enabled)
	Data.games.dice.config_data.time_mult = parameters.get(\"dice.config_data.time_mult\", Data.games.dice.config_data.time_mult)
	Data.games.dice.config_data.wait_time = parameters.get(\"dice.config_data.wait_time\", Data.games.dice.config_data.wait_time)
	Data.games.dice.config_data.runs_count_required = parameters.get(\"dice.config_data.runs_count_required\", Data.games.dice.config_data.runs_count_required)
	Data.games.dice.config_data.regularity = parameters.get(\"dice.config_data.regularity\", Data.games.dice.config_data.regularity)
	Data.games.dice.config_data.punishment = parameters.get(\"dice.config_data.punishment\", Data.games.dice.config_data.punishment)
	Data.games.dice.game_data.runs_timestamps = parameters.get(\"dice.game_data.runs_timestamps\", Data.games.dice.game_data.runs_timestamps.duplicate())
	
	# wof
	#Data.games.wof.enabled = parameters.get(\"wof.enabled\", Data.games.wof.enabled)
	
	#other
	Data.lock_data.countdown_visible = parameters.get(\"lock_data.countdown_visible\", Data.lock_data.countdown_visible)


# this function is called when saving the game to store the dictionnary of parameters
# also called when entering locked mode (and every 5 minutes)
func write_save_dict() -> Dictionary:
	Utils.logdebug(\"WRITE_SAVE_DICT profile=%s\" % [HS.profile_id])
	
	var dict := {
		# dice
		\"dice.enabled\": Data.games.dice.enabled,
		\"dice.config_data.time_mult\": Data.games.dice.config_data.time_mult,
		\"dice.config_data.wait_time\": Data.games.dice.config_data.wait_time,
		\"dice.config_data.runs_count_required\": Data.games.dice.config_data.runs_count_required,
		\"dice.config_data.regularity\": Data.games.dice.config_data.regularity,
		\"dice.config_data.punishment\": Data.games.dice.config_data.punishment,
		\"dice.game_data.runs_timestamps\": Data.games.dice.game_data.runs_timestamps,
		
		# wof
		#\"wof.enabled\": Data.games.wof.enabled,
		
		# other
		\"lock_data.countdown_visible\": Data.lock_data.countdown_visible,
	}
	
	return dict
	

func write_hotscreen_save():
	#HS.config_reader.save_params_of_mods()
	HS.config_reader.write_hotscreen_save()

func launch_session():
	if session.restore():
		# resume ongoing session
		Utils.loginfo(\"resuming locked session...\")
		session.cycle_callback = end_cycle_callback
		HS.menu.get_node(\"LockedMenu\").remaining_seconds = session.get_time_left()
		if not Data.lock_data.countdown_visible:
			change_lock_countdown_visibility(false)
		Utils.logdebug(\"session.get_elapsed(): %s\" % str(session.get_elapsed()))
		write_hotscreen_save()
		#TODO check for behavior == 2 and try stay lock if punishments added time offline. 
	else:
		# start a new session
		Utils.loginfo(\"starting new locked session...\")
		session = LockedSession.new(HS.profile_id)
		var hs_lock_data = HS.config_reader.phs_lock_data
		## HS's lock_duration is in minutes
		var duration = float(hs_lock_data.lock_duration) * 60.0
		session.start(duration, int(hs_lock_data.behavior))
		session.cycle_callback = end_cycle_callback
		
		# start a cycle or not
		if is_penalties_active(Data.games.dice.id):
			session.add_cycle(
				CycleRunner.new(\"dice\", Data.games.dice.config_data.regularity)
			)
		
		# resets countdown visibility here, just in case
		Data.lock_data.countdown_visible = true
	Utils.logdebug(HS.config_reader.phs_lock_data)


func _exit_tree() -> void:
	Utils.logging.close()
	

func _ready() -> void:
	
	Utils.init(self)
	
	Utils.logdebug(\"relative/absolute mod path:\")
	Utils.logdebug(Utils.relative_mod_path)
	Utils.logdebug(Utils.absolute_mod_path)
	Utils.logdebug(\"profile_id: \" + str(HS.profile_id))
	
	add_mod_ui()
	
	
	if OS.has_feature('editor') or HS.menu.has_node(\"LockedMenu\"):
		launch_session()
	
	if not OS.has_feature('editor'):
		##TODO if this 2 don't return the same value, log error?
		#print(\"HS.config_reader: \" + HS.config_reader.find_folder_path(\"LockAndPlayHS\"))
		#print(\"LockAndPlayHS: \" + Utils.find_folder_path(\"LockAndPlayHS\")) # LockAndPlayHS: ./CUSTOM_DATA/modsdev/LockAndPlayHS
		#print(HS.menu.get_version_text()) # => Windows - Full version - v0.8
		Utils.logdebug(HS.config_reader.phs_lock_data)
	
	
	Data.game_started.connect(print_action_event)
	Data.game_ended.connect(print_action_event)


func print_action_event(arg: Dictionary):
	#TODO Lock History 
	#print(arg)
	pass


func add_mod_ui():
	var ui_mod_node = $VBoxContainer
	$VBoxContainer/ModVersion.text = \"[font_size=12]%s v%s[/font_size]\" % [Data.app_info.name, Data.app_info.version]
	if not OS.has_feature(\"editor\"):
		remove_child(ui_mod_node)
		get_meta(\"ui_node\").add_child(ui_mod_node)
		
		
	for item in Data.games:
		var card = load(Utils.resolve_scene_path(\"card_panel.tscn\")).instantiate()
		card.init(Data.games[item].id)
		card.configure_pressed.connect(open_config_window)
		ui_mod_node.get_node(\"ModsHFlowContainer\").add_child(card)


##
## Open a game window for the game with the given id 
##
func open_game_window(minigame_data: Dictionary):
	var window = load(Utils.resolve_scene_path(\"Window.tscn\")).instantiate()
	window.init(minigame_data, Data.WINDOW_MODE_GAME)
	window.game_event_relay.connect(on_game_event_received)
	add_child(window)
	return window


##
## Open a config window for the game with the given id 
##
func open_config_window(minigame_id: String):
	var window = load(Utils.resolve_scene_path(\"Window.tscn\")).instantiate()
	var game_path = Utils.resolve_scene_path(Data.games[minigame_id].config_scene)
	window.init(Data.games[minigame_id], Data.WINDOW_MODE_CONFIG)
	add_child(window)


##
## When something happens in game (add/remove time after losing, etc...)
##
func on_game_event_received(action: Dictionary) -> void:
	if OS.has_feature('editor'):
		return
		
	Utils.logdebug(\"on_game_event_received: %s\" % [action])
	
	apply_action(action)
	
	write_hotscreen_save()
	session.save()


##
## Apply action
##
func apply_action(action: Dictionary):
	match action.type:
		Data.Action.ADD_TIME, Data.Action.REMOVE_TIME:
			change_lock_time(action)
		Data.Action.ENABLE_COLLECTION, Data.Action.DISABLE_COLLECTION,\\
		Data.Action.TOGGLE_COLLECTION, Data.Action.TOGGLE_COLLECTION_RANDOM:
			enable_disable_collection(action)
		Data.Action.LEVEL_UP, Data.Action.LEVEL_DOWN:
			change_collection_level(action)
		Data.Action.SHOW_LOCK_TIME:
			change_lock_countdown_visibility(true, action)
		Data.Action.HIDE_LOCK_TIME:
			change_lock_countdown_visibility(false, action)
		Data.Action.TOGGLE_LOCK_TIME_VISIBILITY:
			toggle_lock_countdown_visibility(action)
		Data.Action.OS_COMMAND:
			exec_os_command(action)
		Data.Action.OS_COMMAND_NEW_PROCESS:
			exec_os_command_new_process(action)


##
## called when a cycle ends
##
func end_cycle_callback(cycle: CycleRunner):
	Utils.logdebug(\"end_cycle_callback() \" + str(cycle.to_dict()))
	
	if has_actions_remaining(cycle.id):
		Utils.loginfo(\"applying punishments %s\" % [Data.games[cycle.id].config_data.punishment])
		apply_punishments(Data.games[cycle.id].config_data.punishment)
	else:
		Utils.logdebug(\"no punishment applied\")


##
## Apply punishments
##
## punishments { \"type\": Data.Action.*, \"arg\": Variant, \"arg_type\": Data.Action.ARG_TYPE_*, \"origin\": Data.Action.ORIGIN_* }
func apply_punishments(punishments: Array):
	assert(punishments.size() > 0)
	
	for action in punishments:
		apply_action(action)
	
	write_hotscreen_save()
	session.save()


################################################################################
## LOCKED MENU
################################################################################


##
## Checks if in locked state and fire the appropriate events when needed
##
func _on_timer_check_periodic_timeout() -> void:
	if OS.has_feature('editor'):
		return
		
	if not HS.menu.has_node(\"LockedMenu\"):
		if _modified_locked_menu != null:
			_modified_locked_menu = null
		return
	
	var locked_menu = HS.menu.get_node(\"LockedMenu\")
	if _modified_locked_menu == locked_menu:
		locked_loop()
		return
	_modified_locked_menu = locked_menu
	
	# will signal when exiting locked mode
	_modified_locked_menu.tree_exiting.connect(exiting_locked_state)
	
	entered_locked_state()


##
## Event entered locked state
##
func entered_locked_state() -> void:
	Utils.logdebug(\"entered locked state\")
	Utils.logdebug(HS.config_reader.phs_lock_data)
	
	if not session.is_running:
		launch_session()
	
	add_ui_to_lock()


##
## Adds games button to the Lock Menu
##
func add_ui_to_lock():
	var target_container = _modified_locked_menu.find_child(\"VBoxContainer\")
	# place game buttons and infos to lock screen if the mini game is enabled
	for id in Data.games:
		if Data.games[id].enabled:
			var label := Label.new()
			label.text = Data.games[id].desc
			
			var tooltip = load(Utils.resolve_scene_path(\"tooltip_anchor_rich.tscn\")).instantiate()
			tooltip.text = \"[color=coral][font_size=20]🛈[/font_size][/color]\"
			tooltip.visible = false
			tooltip.name = \"TooltipAnchorRich\"
			
			var button := Button.new()
			var game_icon = Data.games[id].icon
			var game_name = Data.games[id].name
			button.text = \"Open %s %s\" % [game_icon, game_name]
			button.pressed.connect(open_game_window.bind(Data.games[id]))
			button.size_flags_horizontal = Control.SIZE_EXPAND_FILL
			button.name = \"GameLauncherButton\"
			
			var hbox = HBoxContainer.new()
			# keep a ref for later
			_game_launcher_containers[id] = hbox
			
			hbox.add_child(button)
			hbox.add_child(tooltip)
			
			target_container.add_child(label)
			target_container.add_child(hbox)
	
	##debug button
	#var lock_debug_button := Button.new()
	#lock_debug_button.text = \"debug\"
	#lock_debug_button.pressed.connect(_on_debug_button_pressed)
	#target_container.add_child(lock_debug_button)
	
	add_scroll_to_locked_menu()


func add_scroll_to_locked_menu():
	var scroll_container = ScrollContainer.new()
	scroll_container.name = \"ScrollContainer\"
	_modified_locked_menu.add_child(scroll_container)
	var center_container:CenterContainer = _modified_locked_menu.find_child(\"CenterContainer\")
	center_container.reparent(scroll_container)
	center_container.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	center_container.size_flags_vertical = Control.SIZE_EXPAND_FILL

##
## Event exiting locked state
## This won't be called if the process is killed or when the computer is restarted
##
func exiting_locked_state() -> void:
	Utils.logdebug(\"exiting locked state\")
	
	if session and session.is_running:
		session.stop()
		
		HS.config_reader.phs_lock_data.lock_duration = str(max(0, session.origin_duration / 60.0))
		# The current ending session may have changed the duration of the lock by modifying
		# HS.config_reader.phs_lock_data.lock_duration. There's a bug in HS where the old time is
		# still displayed in the input line edit to the user but underneath the duration is not the same.
		# Updating Locking Time LineEdit to HS.config_reader.phs_lock_data.lock_duration to fix the issue
		var LineEditLockingTime := \"/root/Overlay/AddWindowMenu/MenuWindow/Menu/PanelContainer/MarginContainer/TabContainer/\"\\
			+ \"Tools/MarginContainer/ScrollContainer/VBoxContainer/HBoxContainer12/LineEditLockingTime\"
		get_node(LineEditLockingTime).text = HS.config_reader.phs_lock_data.lock_duration
	
	if _modified_locked_menu != null and not _modified_locked_menu.is_hotscreen_restarting:
		
		# Reset the runs timestamps list
		Data.games.dice.game_data.runs_timestamps = []
	
	# remove refs to nodes
	_game_launcher_containers.clear()


##
## Called every seconds while lock is active
##
func locked_loop() -> void:
	var now := Time.get_unix_time_from_system()
	
	session.update()
	#TODO
	#for id in Data.games:
		#if Data.games[id].enabled:
			#update_actions_remaining_tooltip(id)
	update_actions_remaining_tooltip(\"dice\")
	


##
## Update visiblity and text for specified game id tooltip (placed next to the open game button)
##
func update_actions_remaining_tooltip(id: String):
	var tooltip = _game_launcher_containers[id].get_node(\"TooltipAnchorRich\")
	if not tooltip:
		Utils.logerror(\"error finding actions remaining tooltip '%s'\" % id)
		
	var now := Time.get_unix_time_from_system()
	if is_penalties_active(id) and has_actions_remaining(id):
		var ttt := \"Tasks pending: %s / %s actions completed · %s remaining to avoid penalties\" % [
			Data.games[id].config_data.runs_count_required - count_actions_required(id),
			Data.games[id].config_data.runs_count_required,
			# create session.get_cycle(id).get_time_left()
			Utils.format_time_from_seconds(session.get_cycle(id).get_time_left(), true)
		]
		tooltip.tooltip_text = ttt
		tooltip.visible = true
	else:
		tooltip.tooltip_text = \"\"
		tooltip.visible = false


##
## Check if penalties are active for that game id 
##
func is_penalties_active(id: String) -> bool:
	# dice rolls required set to 0, we skip
	if Data.games[id].config_data.runs_count_required == 0:
		return false
	# regularity not set, we skip
	if int(Data.games[id].config_data.regularity) == 0:
		return false
	# also if no punishment is set, we skip 
	if Data.games[id].config_data.punishment.size() == 0:
		return false
	
	return true


##
## Check if the game with that game id still has some actions remainings for the user to do
##
func has_actions_remaining(id: String) -> bool:
	return count_actions_required(id) > 0

##
## Count actions remaining for the user to do before penalties are applied
## 0 = no more actions left, no punishment will be applied
## >0 = actions remaining, punishment will be applied if not done before end of cycle
##
func count_actions_required(id: String) -> int:
	var count = Data.games[id].config_data.runs_count_required
	var size = Data.games[id].game_data.runs_timestamps.size()
	for i in range(Data.games[id].config_data.runs_count_required):
		if i < size:
			if Data.games[id].game_data.runs_timestamps[i] > session.get_cycle(id).start_time:
				count -= 1
	
	return count



################################################################################
## LOCK MENU ACTIONS
################################################################################


##
## Add or remove time to the lock. 
## Example of expected action argument: {
## 	\"origin\": Data.Action.ORIGIN_DICE_GAME,
## 	\"arg\": time in seconds,
## 	\"type\": Data.Action.REMOVE_TIME,
## }
func change_lock_time(action: Dictionary) -> void:
	Utils.logdebug(\"changing time with this action: \" + str(action))
	
	if not HS.menu.has_node(\"LockedMenu\"):
		Utils.logerror(\"can't change time when unlocked\")
		return
		
	if not session.duration > 0.0 or HS.config_reader.phs_lock_data.lock_duration == \"0.0\":
		Utils.logdebug(\"can't change time when locked forever (unlock time set to 'never')\")
		return
	
	var amount = 0
	if action.type == Data.Action.REMOVE_TIME:
		amount = int(-action.arg)
		Utils.loginfo(\"removing '%s' sec to the lock\" % [str(amount)])
	else:
		amount = int(action.arg)
		Utils.loginfo(\"adding '%s' sec to the lock\" % [str(amount)])
	
	_modified_locked_menu.remaining_seconds += amount
	session.duration += amount
	HS.config_reader.phs_lock_data.lock_duration = str(max(0, session.duration / 60.0))
	#HS.config_reader.phs_lock_data.sec_elapsed = \"0.0\"
	Data.lock_time_changed.emit(action)
	#HS.menu.set_label_countdown()
	Utils.loginfo(\"session -- elapsed time=%ss / time left=%ss / duration=%ss\" % [
		str(int(session.get_elapsed())),
		str(int(session.get_time_left())),
		str(int(session.duration))
	])
	Utils.logdebug(\"HS.config_reader.phs_lock_data.lock_duration = %s min\" % [HS.config_reader.phs_lock_data.lock_duration])
	Utils.logdebug(\"_modified_locked_menu.remaining_seconds = %s sec\" % [str(_modified_locked_menu.remaining_seconds)])


##
## Return an array of HS collections with the names provided.
##
func get_collections_from_names(collec_names: Array[String]) -> Array:
	var found_collections = []
	var sub_collections = HS.overlay.main_collection.get(\"collections\")
	if sub_collections != null and len(sub_collections) > 0:
		for sub_collection in sub_collections:
			if sub_collection.get(\"phs_collection_name\") in collec_names:
				found_collections.append(sub_collection)
	return found_collections

##
## Enable or disable a collection. 
## Example of expected action argument: {
## 	\"origin\": Data.Action.ORIGIN_DICE_PENALTIES,
## 	\"arg\": collection_name,
## 	\"type\": Data.Action.DISABLE_COLLECTION,
## }
func enable_disable_collection(action: Dictionary):
	Utils.logdebug(\"enable/disable collection with this action: \" + str(action))
	
	if str(action.arg).strip_edges().is_empty():
		Utils.logerror(\"start/stop collection: no collection name provided\")
		return
		
	var collec_names := str(action.arg).split(\";\", false)
	var found_collections = get_collections_from_names(collec_names)
	
	if found_collections.size() == 0:
		Utils.logerror(\"start/stop collection: no collection found with the names '%s'\" % [str(action.arg)])
		return
	
	# shuffle the collection. usefull for action type TOGGLE_COLLECTION_RANDOM
	# the first element will be the one toggled then the code will return
	found_collections.shuffle()
	
	for collection in found_collections:
		# action.arg contains a list of collection names separated by ';' 
		# that potentially weren't found. We need to replace the original string
		# with the name of the collection that was actually found in order to be
		# used later in logs or events.
		var action_copy = action.duplicate()
		action_copy.arg = collection.phs_collection_name
		if action.type == Data.Action.ENABLE_COLLECTION:
			change_collection_state(collection, action_copy, true)
		elif action.type == Data.Action.DISABLE_COLLECTION:
			change_collection_state(collection, action_copy, false)
		elif action.type == Data.Action.TOGGLE_COLLECTION:
			change_collection_state(collection, action_copy, collection.phs_is_stopped)
		elif action.type == Data.Action.TOGGLE_COLLECTION_RANDOM:
			# pick a random element then returns so we escape the loop
			change_collection_state(collection, action_copy, collection.phs_is_stopped)
			return


func change_collection_state(collection, action: Dictionary, enable_collection: bool):
	if enable_collection:
		if collection.phs_is_stopped:
			collection.phs_is_stopped = false
			collection.restart_collection()
			Data.collection_enabled.emit(action)
			Utils.loginfo(\"enabled collection '%s'\" % [collection.phs_collection_name])
	else:
		if not collection.phs_is_stopped:
			collection.phs_is_stopped = true
			collection.stop_collection()
			Data.collection_disabled.emit(action)
			Utils.loginfo(\"disabled collection '%s'\" % [collection.phs_collection_name])
			
##
## Level up or down a collection. 
## Example of expected action argument: {
## 	\"origin\": Data.Action.ORIGIN_DICE_PENALTIES,
## 	\"arg\": collection name,
## 	\"type\": Data.Action.LEVEL_UP,
## }
func change_collection_level(action: Dictionary) -> void:
	Utils.logdebug(\"changing level with this action: \" + str(action))
	
	var pick_first_found = false
	if str(action.arg).strip_edges().is_empty():
		pick_first_found = true
		
	var levels_names := str(action.arg).split(\";\", false)
	var found_levels := []
	var sub_collections = HS.overlay.main_collection.get(\"collections\")
	if sub_collections != null and len(sub_collections) > 0:
		for sub_collection in sub_collections:
			var level = sub_collection.get(\"phs_level\")
			if level == null:
				continue
			if sub_collection.phs_is_stopped:
				continue
				
			if pick_first_found:
				found_levels.append(sub_collection)
				break
				
			if sub_collection.get(\"phs_collection_name\") in levels_names:
				found_levels.append(sub_collection)
				
	for level in found_levels:
		if action.type == Data.Action.LEVEL_UP:
			Utils.loginfo(\"leveling up '%s'\" % [level.phs_collection_name])
			level.level_up()
			action.arg = level.phs_collection_name
			Data.collection_level_up.emit(action)
		else:
			Utils.loginfo(\"leveling down '%s'\" % [level.phs_collection_name])
			level.level_down()
			action.arg = level.phs_collection_name
			Data.collection_level_down.emit(action)


##
## Hide or show the lock countdown 
##
## Example of expected action argument: {
## 	\"origin\": Data.Action.ORIGIN_DICE_PENALTIES,
## 	\"type\": Data.Action.HIDE_LOCK_TIME,
## }
func change_lock_countdown_visibility(visible: bool, action: Dictionary = {}):
	var countdown: Label = try_get_lock_countdown()
	if countdown:
		countdown.visible = visible
		Data.lock_data.countdown_visible = countdown.visible
		if action and not action.is_empty():
			if visible:
				Data.countdown_revealed.emit(action)
			else:
				Data.countdown_hidden.emit(action)
			Utils.loginfo(\"changed countdown visibility: visible=%s\" % [visible])


func toggle_lock_countdown_visibility(action: Dictionary = {}):
	var countdown: Label = try_get_lock_countdown()
	if countdown:
		countdown.visible = !countdown.visible
		Data.lock_data.countdown_visible = countdown.visible
		if action and not action.is_empty():
			if countdown.visible:
				Data.countdown_revealed.emit(action)
			else:
				Data.countdown_hidden.emit(action)
			Utils.loginfo(\"changed countdown visibility: visible=%s\" % [countdown.visible])


func try_get_lock_countdown() -> Node:
	if not HS.menu.has_node(\"LockedMenu\"):
		return null
	
	var locked_menu = HS.menu.get_node(\"LockedMenu\")
	# The unchanged tree as of HS v0.8 is as follow:
	#LockedMenu:<PanelContainer>
	#┠╴CenterContainer
	#┃  ┖╴VBoxContainer
	#┃     ┠╴TextureRect
	#┃     ┠╴HBoxContainer2
	#┃     ┃  ┠╴Label
	#┃     ┃  ┖╴LabelCountdown
	#┃     ┖╴HBoxContainer
	#┃        ┠╴Label
	#┃        ┖╴LineEdit
	#┖╴TimerSec
	
	# this mod adds a ScrollContainer
	var countdown: LineEdit = null
	if locked_menu.has_node(\"ScrollContainer/CenterContainer/VBoxContainer/HBoxContainer2/LabelCountdown\"):
		countdown = locked_menu.get_node(\"ScrollContainer/CenterContainer/VBoxContainer/HBoxContainer2/LabelCountdown\")
	if countdown == null:
		# try the default tree as fallback
		if locked_menu.has_node(\"CenterContainer/VBoxContainer/HBoxContainer2/LabelCountdown\"):
			countdown = locked_menu.get_node(\"CenterContainer/VBoxContainer/HBoxContainer2/LabelCountdown\")
	return countdown


##
