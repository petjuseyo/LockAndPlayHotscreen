func toggle_lock_password_visibility():
	var line_edit: LineEdit = try_get_lock_password_line_edit()
	if line_edit:
		line_edit.visible = !line_edit.visible


func try_get_lock_password_line_edit() -> Node:
	if not HS.menu.has_node(\"LockedMenu\"):
