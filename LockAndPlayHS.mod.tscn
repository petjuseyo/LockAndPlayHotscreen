##
## Freezes the current lock, pausing the countdown timer.
##
## Use this to temporarily halt the progress of the lock.
## While frozen, the lock duration will not tick down.
## The lock will remain frozen until explicitly unfrozen.
## The countdown can still be changed by adding/removing time manually.
func freeze_lock(action: Dictionary):
	var timer_sec:Timer = _modified_locked_menu.find_child(\"TimerSec\")
	timer_sec.stop()
	# TODO handle session pause
	# make a session.freeze() ? => would not jump in time when resumed
	# cycle should stay the same


##
## Execute OS commmand in the same process
##
## Example of expected action argument: {
## 	\"origin\": Data.Action.ORIGIN_DICE_PENALTIES,
## 	\"arg\": \"command\",
## 	\"arg_type\": Data.Action.ARG_TYPE_STRING,
## 	\"type\": Data.Action.OS_COMMAND,
## }
func exec_os_command(action: Dictionary):
	if action.arg.is_empty():
		return
	
	var output: = []
	var exit_code: = 0
	exit_code = OS.execute(\"cmd.exe\", [\"/C\", action.arg], output, true)
	#var exit_code = OS.execute_with_pipe(\"cmd.exe\", [\"/C\", action.arg], false)
	if exit_code == -1:
		Utils.logerror(\"could't execute command '%s'.\\nexit code: %s\\nouput: %s\" % [action.arg, str(exit_code), str(output)])
	else:
		Utils.loginfo(\"command executed.\\nexit code: %s\\nouput: %s\" % [str(exit_code), str(output)])


##
## Execute OS commmand in a new process
##
## Example of expected action argument: {
## 	\"origin\": Data.Action.ORIGIN_DICE_PENALTIES,
## 	\"arg\": \"command\",
## 	\"arg_type\": Data.Action.ARG_TYPE_STRING,
## 	\"type\": Data.Action.OS_COMMAND_NEW_PROCESS,
## }
func exec_os_command_new_process(action: Dictionary):
	if action.arg.is_empty():
		return
		
	Utils.loginfo(\"executing user defined OS command: '%s'\" % [action.arg])
	var pid := OS.create_process(\"cmd.exe\", [\"/C\", action.arg])
	
	if pid == -1:
		Utils.logerror(\"couldn't create process with command '%s'\" % [action.arg])
	else:
		Utils.loginfo(\"command executed successfully.\")
		 


##
## Exit locked state. After calling it the user won't be locked anymore.
##
func force_exit_locked_state():
	if HS.menu.has_node(\"LockedMenu\"):
		HS.menu.get_node(\"LockedMenu\").remove_locked_password()


